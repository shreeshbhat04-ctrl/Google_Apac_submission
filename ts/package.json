{
  "name": "alloynative",
  "version": "0.1.0",
  "description": "AlloyNative TypeScript SDK for AlloyDB hybrid retrieval and reranking.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "proto"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=node_modules\\.bin\\protoc-gen-ts_proto.cmd --ts_proto_out=src/generated --ts_proto_opt=esModuleInterop=true,outputServices=grpc-js -I proto proto/alloynative.proto"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "google-protobuf": "^3.21.4"
  },
  "devDependencies": {
    "grpc-tools": "^1.13.0",
    "ts-proto": "^2.7.0",
    "typescript": "^5.8.0"
  }
}
